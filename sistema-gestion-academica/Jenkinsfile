pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Obteniendo código del repositorio...'
            }
        }

        stage('Build') {
            steps {
                echo 'Compilando proyecto Maven...'
                bat 'mvn clean compile'
            }
        }

        stage('Unit Tests') {
            steps {
                echo 'Ejecutando pruebas unitarias...'
                bat 'mvn test'
            }
        }

        stage('Integration Tests') {
            steps {
                echo 'Ejecutando pruebas de integración...'
                bat 'mvn verify'
            }
        }

        stage('Acceptance Tests') {
            steps {
                echo 'Ejecutando pruebas de aceptación...'
                bat 'mvn test'
            }
        }

        stage('Deploy to Staging') {
            steps {
                echo 'Desplegando aplicación en ambiente de pruebas...'
            }
        }

        stage('Rollback Validation') {
            steps {
                echo 'Validando mecanismo de rollback...'
            }
        }

    }

    post {

        success {
            echo 'Pipeline ejecutado exitosamente'
        }

        failure {
            echo 'Pipeline con errores'
        }
    }
}